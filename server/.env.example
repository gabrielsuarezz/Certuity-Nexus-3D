# ─────────────────────────────────────────────────────────────────────────────
# Certuity Prism — agent backend config. Copy to server/.env and fill in.
# Nothing here is required to RUN in mock mode (USE_MOCK_LLM=true).
# ─────────────────────────────────────────────────────────────────────────────

# Agent brain — Azure OpenAI via Semantic Kernel.
# true  = run with NO keys (canned/heuristic responses) for building + safe demos
# false = use the real Azure OpenAI deployment below
USE_MOCK_LLM=true
AZURE_OPENAI_ENDPOINT=
AZURE_OPENAI_API_KEY=
AZURE_OPENAI_DEPLOYMENT=gpt-4o
AZURE_OPENAI_API_VERSION=2024-10-21

# Guardrails — Azure AI Content Safety (Prompt Shields). Optional; if unset, a
# local heuristic injection detector is used instead.
AZURE_CONTENT_SAFETY_ENDPOINT=
AZURE_CONTENT_SAFETY_KEY=

# Voice — ElevenLabs Conversational AI. Optional; text chat works without it.
ELEVENLABS_API_KEY=
ELEVENLABS_AGENT_ID=

# App
ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
DEMO_CLIENT_ID=a0R8d00000Smith1
AUDIT_LOG_PATH=audit.log.jsonl
