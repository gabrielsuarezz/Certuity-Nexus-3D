# ─────────────────────────────────────────────────────────────────────────────
# The Interactive Wealth Graph — environment
#
# Copy to `.env` to override. Every value is optional; the defaults below keep
# the app running as a 100% static, front-end-only demo.
# ─────────────────────────────────────────────────────────────────────────────

# Data source. true (default) = bundled Salesforce-shaped mock.
# Set to false once a live /api/wealth-graph endpoint exists.
VITE_USE_MOCK=true

# Base URL of the future backend (planned: a Vercel serverless function that
# proxies a Salesforce SOQL query with server-side OAuth).
VITE_API_BASE_URL=/api

# Simulated network latency (ms) for the mock, so the premium loading state is
# visible during the demo. Set to 0 for instant.
VITE_MOCK_LATENCY_MS=850
